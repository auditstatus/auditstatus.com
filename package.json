{
  "name": "auditstatus",
  "version": "1.0.0",
  "description": "Server auditing and verification tool with PM2 ecosystem support",
  "main": "lib/index.js",
  "scripts": {
    "test": "ava",
    "test:watch": "ava --watch",
    "test:coverage": "c8 ava",
    "lint": "xo",
    "lint:fix": "xo --fix",
    "pretest": "npm run lint",
    "posttest": "npm run test:coverage"
  },
  "keywords": [
    "audit",
    "server",
    "verification",
    "pm2",
    "ecosystem",
    "ssh",
    "attestium"
  ],
  "author": "AuditStatus Team",
  "license": "MIT",
  "dependencies": {
    "attestium": "^1.0.0",
    "axios": "^1.6.0",
    "node-ssh": "^13.1.0",
    "pm2": "^5.3.0"
  },
  "devDependencies": {
    "ava": "^6.0.0",
    "xo": "^0.56.0",
    "sinon": "^17.0.0",
    "mock-fs": "^5.2.0",
    "nock": "^13.4.0",
    "c8": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "xo": {
    "rules": {
      "unicorn/prefer-module": "off",
      "n/prefer-global/process": "off",
      "complexity": "off",
      "max-depth": "off"
    }
  }
}


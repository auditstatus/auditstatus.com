{
  "name": "auditstatus",
  "description": "Automated third-party auditing system for code integrity verification and transparency",
  "version": "1.0.3",
  "author": "Audit Status Community",
  "bin": {
    "auditstatus": "scripts/cli.js"
  },
  "bugs": {
    "url": "https://github.com/auditstatus/auditstatus.com/issues"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "contributors": [
    "Audit Status Community"
  ],
  "dependencies": {
    "attestium": "^0.0.1",
    "axios": "^1.7.9",
    "commander": "^11.0.0",
    "cosmiconfig": "^9.0.0",
    "js-yaml": "^4.1.0",
    "nodemailer": "^6.9.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "c8": "^10.1.3",
    "esbuild": "^0.27.3",
    "fixpack": "^4.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "marked": "^17.0.0",
    "prettier": "^3.0.0",
    "remark-cli": "^11.0.0",
    "remark-preset-github": "^4.0.4",
    "xo": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "scripts/audit-servers.js",
    "scripts/badge.js",
    "scripts/cli.js",
    "scripts/server-check.js",
    "scripts/validate-config.js",
    "LICENSE",
    "README.md"
  ],
  "homepage": "https://auditstatus.com",
  "keywords": [
    "attestium",
    "audit",
    "audit-status",
    "auditstatus",
    "code-integrity",
    "continuous-verification",
    "github-actions",
    "monitoring",
    "security",
    "server-audit",
    "tamper-proof",
    "third-party",
    "tpm",
    "transparency",
    "verification"
  ],
  "license": "MIT",
  "lint-staged": {
    "*.js": [
      "xo --fix"
    ],
    "*.md": [
      "remark . -qfo"
    ],
    "package.json": [
      "fixpack"
    ]
  },
  "main": "scripts/audit-servers.js",
  "packageManager": "pnpm@9.0.0",
  "prettier": {
    "useTabs": false,
    "tabWidth": 2,
    "singleQuote": true
  },
  "remarkConfig": {
    "plugins": [
      "remark-preset-github"
    ],
    "settings": {
      "bullet": "*",
      "fences": true,
      "listItemIndent": "one",
      "rule": "-"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/auditstatus/auditstatus.com.git"
  },
  "scripts": {
    "audit": "node scripts/audit-servers.js",
    "audit:config": "node scripts/audit-servers.js --config",
    "audit:debug": "node scripts/audit-servers.js --debug",
    "audit:dry-run": "node scripts/audit-servers.js --dry-run",
    "audit:verbose": "node scripts/audit-servers.js --verbose",
    "build": "node scripts/build-sea.mjs",
    "build:binary": "bash scripts/build-binary.sh",
    "c8": "c8 --reporter=text --reporter=html --reporter=lcov --exclude='dist/**' --exclude='test/**' node --test",
    "check": "node scripts/server-check.js",
    "check:json": "node scripts/server-check.js --json",
    "dev": "pnpm run audit:verbose",
    "init": "node scripts/audit-servers.js --init",
    "init:force": "node scripts/audit-servers.js --init --force",
    "lint": "fixpack && remark . -qfo && xo --fix",
    "pre-commit": "lint-staged",
    "prepare": "husky",
    "pretest": "pnpm run lint",
    "start": "pnpm run audit",
    "test": "node --test",
    "test-coverage": "c8 --reporter=text --reporter=html --reporter=lcov --exclude='dist/**' --exclude='test/**' node --test",
    "test:only": "node --test",
    "test:verbose": "pnpm run audit:dry-run -- --verbose",
    "validate-config": "node scripts/validate-config.js"
  },
  "xo": {
    "rules": {
      "unicorn/prefer-module": "off",
      "import-x/extensions": "off",
      "no-unused-vars": "off",
      "no-promise-executor-return": "off",
      "n/prefer-global/process": "off",
      "unicorn/no-array-reduce": "off",
      "unicorn/prefer-top-level-await": "off",
      "unicorn/import-style": "off",
      "no-return-await": "off",
      "no-await-in-loop": "off",
      "@stylistic/function-paren-newline": "off",
      "n/prefer-global/buffer": "off",
      "unicorn/prevent-abbreviations": "off",
      "no-return-assign": "off",
      "promise/prefer-await-to-then": "off",
      "unicorn/no-process-exit": "off",
      "no-new": "off",
      "max-depth": "off",
      "unicorn/no-this-assignment": "off",
      "prefer-rest-params": "off",
      "logical-assignment-operators": "off",
      "no-dupe-class-members": "off",
      "no-dupe-keys": "off",
      "camelcase": "off",
      "no-bitwise": "off",
      "import-x/order": "off"
    },
    "space": 2
  }
}
